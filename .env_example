# =============================================================================
# Parking Reservation Chatbot — environment variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Uncomment and set only the variables you want to override.
# =============================================================================

# -----------------------------------------------------------------------------
# Model
# -----------------------------------------------------------------------------
# MODEL_PATH=local_models/Meta-Llama-3-8B-Instruct.Q4_0.gguf
# MODEL_TYPE=gpt4all
# TEMPERATURE=0.7
# MAX_CONTEXT_LENGTH=2048

# -----------------------------------------------------------------------------
# Vector store (FAISS over rag_data/parking_info.txt)
# -----------------------------------------------------------------------------
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# FAISS similarity: cosine (default) or l2. Change requires index rebuild.
# FAISS_METRIC=cosine

# -----------------------------------------------------------------------------
# Guard rails
# -----------------------------------------------------------------------------
# ENABLE_GUARD_RAILS=true
# SENSITIVE_DATA_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Evaluation
# -----------------------------------------------------------------------------
# EVALUATION_ENABLED=true
# METRICS_K=5

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO
# LOG_FILE=logs/chatbot.log

# -----------------------------------------------------------------------------
# Chatbot
# -----------------------------------------------------------------------------
# CHATBOT_NAME=Parking Assistant
# RETRIEVAL_K=5
