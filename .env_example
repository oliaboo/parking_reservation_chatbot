# Copy to .env and adjust as needed

# Model Configuration
# MODEL_PATH=local_models/Meta-Llama-3-8B-Instruct.Q4_0.gguf
# MODEL_TYPE=gpt4all
# TEMPERATURE=0.7
# Max context size (tokens).
# MAX_CONTEXT_LENGTH=2048
# Max tokens to generate per LLM call (n_predict). Use 512 so prompt + output fits in context and "context full" does not trigger on first call.
# MAX_TOKENS_TO_GENERATE=150

# Vector store (FAISS over rag_data/parking_info.txt)
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Guard Rails
# ENABLE_GUARD_RAILS=true
# SENSITIVE_DATA_THRESHOLD=0.7

# Evaluation
# EVALUATION_ENABLED=true
# METRICS_K=5

# Logging
# LOG_LEVEL=WARNING
# LOG_FILE=logs/chatbot.log

# Chatbot
# CHATBOT_NAME=Parking Assistant
# RETRIEVAL_K=5

# l2 or cosine (cosine is default)
# FAISS_METRIC=l2